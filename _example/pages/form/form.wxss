.tdesign-mobile-demo {
  padding: 180rpx 0;
  background-color: #f5f5f5;
}

.option {
  margin-bottom: 24rpx;
}

.select-button-group {
  background-color: #fff;
  box-sizing: border-box;
  padding: 16rpx 8rpx;
  display: flex;
  justify-content: space-between;
  position: relative;
  border-bottom: 1rpx solid #e7e7e7;
}

.select-button-group .t-button {
  height: 64rpx;
  flex: 1;
}

.select-button-group .t-button:not(:last-child) {
  margin-right: 16rpx;
}
