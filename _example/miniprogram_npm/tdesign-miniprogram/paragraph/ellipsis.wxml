<template name="ellipsis-toggle"><view wx:if="{{ellipsis && !isExpanded && ellipsis.expandable}}" class="{{classPrefix}}-ellipsis-symbol" style="text-decoration: none; white-space: nowrap; flex: 1;{{extraStyle || ''}}" bind:tap="onExpand">{{globalConfig.expandText}}</view><view wx:elif="{{ellipsis && isExpanded && ellipsis.expandable && ellipsis.collapsible}}" class="{{classPrefix}}-ellipsis-symbol" style="text-decoration: none; white-space: nowrap; flex: 1;{{extraStyle || ''}}" bind:tap="onCollapse">{{globalConfig.collapseText}}</view></template>