<wxs src="../common/utils.wxs" module="_" />

<view
  wx:if="{{fixed && placeholder}}"
  class="{{classPrefix}}__placeholder"
  style="height: {{ placeholderHeight }}px;"
/>
<view
  style="{{_._style(['z-index: ' + zIndex, '--safe-area-inset-bottom: ' + (safeAreaBottomHeight ? safeAreaBottomHeight + 'px' : 'env(safe-area-inset-bottom)'), style, customStyle])}}"
  class="{{_.cls(classPrefix, [['border', bordered], ['fixed', fixed], ['safe', safeAreaInsetBottom], shape])}} class {{prefix}}-class"
  aria-role="tablist"
>
  <slot />
</view>
