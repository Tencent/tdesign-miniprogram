<wxs src="../common/utils.wxs" module="_" />

<view
  class="{{classPrefix}} {{classPrefix}}--{{labelAlign}} {{prefix}}-class"
  style="{{_._style([style, customStyle])}}"
>
  <!-- 标签区域 -->
  <view
    wx:if="{{label}}"
    class="{{classPrefix}}__label {{classPrefix}}__label--{{labelAlign}} {{requiredMark ? classPrefix + '__label--required' : ''}} {{requiredMark && requiredMarkPosition === 'right' ? classPrefix + '__label--required-right' : ''}} {{prefix}}-class-label"
    style="width: {{labelWidth}}"
  >
    <label for="{{for}}">{{label}}</label>
    <text wx:if="{{colon}}" class="{{classPrefix}}__label--colon">:</text>
  </view>

  <!-- 内容区域 -->
  <view
    class="{{classPrefix}}__controls {{classPrefix}}__controls--{{contentAlign}} {{prefix}}-class-controls"
    style="{{contentStyle}}"
  >
    <!-- 表单项内容 -->
    <view class="{{classPrefix}}__controls-row">
      <view class="{{classPrefix}}__controls-content">
        <slot />
      </view>
      <view wx:if="{{arrow}}" class="{{classPrefix}}__arrow">
        <t-icon name="chevron-right" size="24" color="rgba(0, 0, 0, 0.4)" />
      </view>
    </view>

    <!-- 帮助信息 -->
    <view wx:if="{{help}}" class="{{classPrefix}}-help {{prefix}}-class-help"> {{ help }} </view>

    <!-- 校验提示信息 -->
    <view
      wx:if="{{(errorList.length > 0 && showErrorMessage) || successList.length > 0}}"
      class="{{classPrefix}}-extra {{classPrefix}}-extra--{{errorList.length > 0 && showErrorMessage ? (errorList[0].type || 'error') : 'success'}} {{prefix}}-class-extra"
    >
      {{errorList.length > 0 && showErrorMessage ? errorList[0].message : successList[0].message}}
    </view>
  </view>
</view>
