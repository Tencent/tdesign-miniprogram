exports[`Segmented Segmented disabled demo works fine 1`] = `
<disabled>
  <wx-view
    class="example-segmented"
  >
    <t-segmented
      disabled="{{true}}"
      options="{{
        Array [
          "最近",
          "推荐",
          "热门",
        ]
      }}"
      value="最近"
      bind:change="onChange"
    />
  </wx-view>
  <wx-view
    class="example-segmented"
  >
    <t-segmented
      options="{{
        Array [
          Object {
            "label": "周一",
            "value": 0,
          },
          Object {
            "label": "周二",
            "value": 1,
          },
          Object {
            "disabled": true,
            "label": "周三",
            "value": 2,
          },
          Object {
            "label": "周四",
            "value": 3,
          },
          Object {
            "disabled": true,
            "label": "周五",
            "value": 4,
          },
        ]
      }}"
      value="{{1}}"
      bind:change="onChangeWithDisabled"
    />
  </wx-view>
</disabled>
`;
