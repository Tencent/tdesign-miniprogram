exports[`Segmented Segmented base demo works fine 1`] = `
<base>
  <wx-view
    class="example-segmented"
  >
    <t-segmented
      defaultValue="{{0}}"
      options="{{
        Array [
          Object {
            "label": "选项",
            "value": 0,
          },
          Object {
            "label": "选项",
            "value": 1,
          },
          Object {
            "label": "选项",
            "value": 2,
          },
        ]
      }}"
    />
  </wx-view>
  <wx-view
    class="example-segmented"
  >
    <t-segmented
      options="{{
        Array [
          Object {
            "icon": "home",
            "label": "选项",
            "value": 0,
          },
          Object {
            "icon": "home",
            "label": "选项",
            "value": 1,
          },
          Object {
            "icon": "home",
            "label": "选项",
            "value": 2,
          },
        ]
      }}"
      value="{{0}}"
      bind:change="onChangeWithIcon"
    />
  </wx-view>
</base>
`;

