exports[`Segmented Segmented disabled demo works fine 1`] = `
<disabled>
  <wx-view
    class="example-segmented"
  >
    <t-segmented
      options="{{
        Array [
          Object {
            "label": "选中",
            "value": 0,
          },
          Object {
            "label": "默认",
            "value": 1,
          },
          Object {
            "disabled": true,
            "label": "禁用",
            "value": 2,
          },
        ]
      }}"
      value="{{0}}"
      bind:change="onChangeWithDisabled"
    />
  </wx-view>
</disabled>
