exports[`Segmented Segmented base demo works fine 1`] = `
<base>
  <wx-view
    class="example-segmented"
  >
    <t-segmented
      defaultValue="home"
      options="{{
        Array [
          "home",
          "categeray",
          "min",
        ]
      }}"
    />
  </wx-view>
  <wx-view
    class="example-segmented"
  >
    <t-segmented
      options="{{
        Array [
          Object {
            "icon": "home",
            "label": "home",
            "value": 0,
          },
          Object {
            "icon": "app",
            "label": "categeray",
            "value": 1,
          },
          Object {
            "icon": "user",
            "label": "mine",
            "value": 2,
          },
        ]
      }}"
      value="{{1}}"
      bind:change="onChangeWithIcon"
    />
  </wx-view>
</base>
`;

