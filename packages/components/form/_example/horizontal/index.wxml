<t-form
  id="form"
  class="form"
  data="{{formData}}"
  rules="{{rules}}"
  reset-type="initial"
  show-error-message
  using-custom-navbar
  scrollToFirstError="smooth"
  label-align="left"
  bind:reset="onReset"
  bind:submit="onSubmit"
>
  <t-form-item label="用户名" name="name" help="输入用户名">
    <t-input
      value="{{formData.name}}"
      borderless
      placeholder="请输入用户名"
      disabled="{{disabled}}"
      bind:change="onInputChange"
      data-field="name"
    />
  </t-form-item>

  <t-form-item label="密码" name="password">
    <t-input
      value="{{formData.password}}"
      borderless
      type="password"
      clearable="{{false}}"
      placeholder="请输入密码"
      disabled="{{disabled}}"
      bind:change="onInputChange"
      data-field="password"
    />
  </t-form-item>

  <t-form-item label="性别" name="gender">
    <t-radio-group
      value="{{formData.gender}}"
      disabled="{{disabled}}"
      class="box"
      borderless
      bind:change="onRadioChange"
    >
      <t-radio block="{{false}}" name="radio" value="man" label="男" />
      <t-radio block="{{false}}" name="radio" value="women" label="女" />
      <t-radio block="{{false}}" name="radio" value="secret" label="保密" />
    </t-radio-group>
  </t-form-item>

  <t-form-item label="生日" arrow name="birth" content-align="right">
    <t-input
      value="{{formData.birth}}"
      disabled="{{disabled}}"
      borderless
      readonly
      placeholder="请输入生日"
      bind:tap="showDatePicker"
    />
    <t-date-time-picker
      title="选择日期"
      visible="{{dateVisible}}"
      mode="date"
      format="YYYY-MM-DD"
      bind:change="onDatePickerConfirm"
      bind:close="onDatePickerClose"
      start="{{start}}"
      end="{{end}}"
    />
  </t-form-item>

  <t-form-item arrow label="籍贯" name="place" content-align="right">
    <t-input
      value="{{formData.place}}"
      disabled="{{disabled}}"
      borderless
      readonly
      placeholder="请选择籍贯"
      bind:tap="showCascader"
    />
    <t-cascader
      visible="{{visibleCascader}}"
      value="{{address}}"
      title="选择地址"
      options="{{options}}"
      bind:change="onChangeCascader"
      bind:visible-change="onCascaderVisibleChange"
    />
  </t-form-item>

  <t-form-item label="年限" name="age" content-align="right">
    <t-stepper value="{{formData.age}}" disabled="{{disabled}}" theme="filled" bind:change="onChangeStepper" />
  </t-form-item>

  <t-form-item label="自我评价" name="description" content-align="right">
    <t-rate
      value="{{formData.description}}"
      disabled="{{disabled}}"
      variant="filled"
      allow-half
      gap="{{rateGap}}"
      bind:change="onRateChange"
    />
  </t-form-item>

  <t-form-item label="个人简介" name="resume" t-class-label="my-label">
    <t-textarea
      value="{{formData.resume}}"
      disabled="{{disabled}}"
      class="textarea"
      indicator
      maxlength="{{50}}"
      placeholder="请输入个人简介"
      bind:change="onTextareaChange"
    />
  </t-form-item>

  <t-form-item label="上传照片" name="photo">
    <t-upload
      class="upload"
      files="{{formData.photo}}"
      disabled="{{disabled}}"
      multiple
      max="{{6}}"
      action="{{action}}"
      grid-config="{{gridConfig}}"
      bind:fail="onFail"
      bind:progress="onProgress"
      bind:change="onChangeUpload"
      bind:preview="onPreview"
      bind:success="onSuccess"
      bind:remove="onRemove"
    />
  </t-form-item>

  <view class="button-group">
    <t-button theme="primary" formType="submit" size="large" bind:tap="submit">提交</t-button>
    <t-button theme="default" variant="base" formType="reset" size="large" bind:tap="reset">重置</t-button>
  </view>
</t-form>
