<t-navbar class="demo-navbar" title="Form" leftArrow placeholder zIndex="{{99}}" />
<t-demo-header
  title="Form 表单"
  desc="用于开启一个闭环的操作任务，如“删除”对象、“购买”商品等。"
  notice="渲染框架支持情况：WebView"
/>

<t-demo title="01 组件类型" desc="基础表单">
  <view class="option">
    <view class="select-button-group">
      <t-button theme="{{isActive1 ? 'light' : 'default'}}" shape="round" data-name="isActive1" bind:tap="onClick">
        水平排布
      </t-button>
      <t-button theme="{{isActive2 ? 'light' : 'default'}}" shape="round" data-name="isActive2" bind:tap="onClick">
        竖直排布
      </t-button>
    </view>
    <t-cell title="禁用态">
      <t-switch defaultValue="{{switchValue}}" slot="note" bind:change="onChangeSwitch" />
    </t-cell>
  </view>

  <view wx:if="{{isActive1}}">
    <horizontal disabled="{{switchValue}}" />
  </view>

  <view wx:if="{{isActive2}}">
    <vertical disabled="{{switchValue}}" />
  </view>
</t-demo>
