<view class="demo-base-container">
  <!-- 聊天发送器组件 - 文本输入模式 -->
  <view class="chat-sender-demo-wrapper">
    <view class="chat-sender-height-limit">
      <view class="chat-sender-height-left-limit"> </view>
      <view class="chat-sender-height-right-limit"> </view>
    </view>
    <view class="chat-sender-placeholder"> 文本输入模式：最大高度为132px </view>
    <view class="chat-sender-wrapper">
      <t-chat-sender
        value="{{query}}"
        loading="{{loading}}"
        placeholder="{{placeholder}}"
        allowSpeech="{{allowSpeech}}"
        bind:send="onSend"
        bind:keyboardheightchange="onKeyboardHeightChange"
      >
        <view slot="voice-input">
          <t-chat-record autoHeight bind:recognize="handleRecognize">
            <view slot="speechInput" class="speech-slot-btn"> 按住说话 </view>
            <view slot="speechNoAuth" class="speech-btn-error"> 请授权麦克风权限 </view>
          </t-chat-record>
        </view>
        <view slot="footer-prefix" class="demo-footer-prefix">
          <t-icon wx:if="{{allowSpeech === 'speech'}}" class="voice-input-button" name="keyboard-1" bind:tap="toggleVoiceIcon" />
          <t-icon
            wx:else
            class="voice-input-button"
            name="voice-wave"
            bind:tap="toggleVoiceIcon"
          />
        </view>
      </t-chat-sender>
    </view>
  </view>
</view>
