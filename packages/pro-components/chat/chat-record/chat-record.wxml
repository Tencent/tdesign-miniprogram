<view class="{{classPrefix}}">
  <!-- hook：授权时按住说话 / 未授权引导授权 -->
  <view
    wx:if="{{recordAuthStatus}}"
    class="{{classPrefix}}-hook"
    catchtouchstart="startRecord"
    catchtouchend="stopRecord"
    catchtouchmove="touchmove"
    catchtouchcancel="touchcancel"
  >
    <slot name="speechInput">
      <view>按住 说话</view>
    </slot>
  </view>

  <button
    wx:else
    class="{{classPrefix}}-hook {{classPrefix}}-hook--no-auth"
    open-type="openSetting"
    bindopensetting="onOpenSetting"
  >
    <slot name="speechNoAuth">
      <view>请授权麦克风权限</view>
    </slot>
  </button>

  <!-- 遮罩 + 录音面板 -->
  <view class="cover-ng-bar {{classPrefix}}-audio-input {{showMask ? 'show' : ''}}">
    <!-- mask -->
    <view class="{{classPrefix}}-audio-input__mask" bindtap="handleCancelSend" />

    <view class="{{classPrefix}}-audio-input__main">
      <!-- 气泡/动画区 -->
      <view
        wx:if="{{processStatus === 'recording' || processStatus === 'confirm'}}"
        class="{{classPrefix}}-audio-input-ani fade-in"
      >
        <view class="bubble-container {{bubbleStatusClass}}">
          <!-- 录音中：音量条 -->
          <view wx:if="{{processStatus === 'recording' && interactStatus === 'normal'}}" class="audio-wave">
            <block wx:for="{{waveList}}" wx:key="*this">
              <view class="wave-item" />
            </block>
          </view>

          <!-- 取消/错误：红色气泡图标 -->
          <view wx:elif="{{interactStatus === 'release_cancel' || processStatus === 'error'}}" class="cancel-icon" />
          <view wx:if="{{processStatus === 'error'}}" class="cancel-text">未识别到语音</view>

          <!-- 转文字/确认：可编辑文本 -->
          <view
            wx:elif="{{interactStatus === 'release_convert' || processStatus === 'confirm'}}"
            class="convert-content"
          >
            <textarea
              class="editable-textarea"
              value="{{translateResult}}"
              maxlength="-1"
              bindinput="onTranslateInput"
            />
            <view wx:if="{{interactStatus === 'release_convert'}}" class="convert-dots" />
          </view>
        </view>
      </view>

      <!-- 底部区域 -->
      <view
        wx:if="{{processStatus === 'recording' || processStatus === 'confirm'}}"
        class="{{classPrefix}}-audio-input__ft {{processStatus}} {{interactStatus}} fade-in"
      >
        <view class="tips-text">
          <block wx:if="{{processStatus === 'recording'}}">
            <text wx:if="{{interactStatus !== 'normal'}}">Audio</text>
            <text wx:else>Release to send</text>
          </block>
          <block wx:elif="{{processStatus === 'processing'}}">Processing...</block>
        </view>

        <!-- 确认按钮区（Send/Cancel） -->
        <view
          wx:if="{{processStatus === 'confirm' || processStatus === 'error'}}"
          class="confirm-actions {{processStatus === 'error' ? 'is-error' : ''}}"
        >
          <view
            class="action-btn btn-cancel {{activeBtnCancel ? 'active' : ''}} {{processStatus === 'error' ? 'disabled' : ''}}"
            bindtap="handleCancelSend"
            catchtouchstart="onCancelBtnTouchStart"
            catchtouchend="onCancelBtnTouchEnd"
            catchtouchcancel="onCancelBtnTouchEnd"
          >
            <view class="icon-wrapper">
              <text class="rollback-icon">↩</text>
            </view>
            <text class="btn-text">Cancel</text>
          </view>
          <view
            class="action-btn btn-send {{activeBtnSend ? 'active' : ''}} {{processStatus === 'error' ? 'disabled' : ''}}"
            bindtap="handleSendVoiceMsg"
            catchtouchstart="onSendBtnTouchStart"
            catchtouchend="onSendBtnTouchEnd"
            catchtouchcancel="onSendBtnTouchEnd"
          >
            <text>Send</text>
          </view>
        </view>

        <!-- 录音阶段底部按钮提示（Cancel/Convert） -->
        <block wx:if="{{processStatus === 'recording' || processStatus === 'processing'}}">
          <view class="{{classPrefix}}-audio-input__ft__bg" />

          <view
            class="shape-btn left-btn {{(interactStatus === 'release_cancel' || processStatus === 'error') ? 'active' : ''}}"
          >
            <view wx:if="{{interactStatus === 'release_cancel' || processStatus === 'error'}}" class="btn-hint">
              <text class="word word-1">Release</text>
              <text class="word word-2">to cancel</text>
            </view>
            <view class="btn-label"><text class="word">Cancel</text></view>
          </view>

          <view class="shape-btn right-btn {{interactStatus === 'release_convert' ? 'active' : ''}}">
            <view wx:if="{{interactStatus === 'release_convert'}}" class="btn-hint">
              <text class="word word-1">Release</text>
              <text class="word word-2">to edit</text>
              <text class="word word-3">text</text>
            </view>
            <view class="btn-label">
              <text class="word word-1">Convert</text>
              <text class="word word-2">to Text</text>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
