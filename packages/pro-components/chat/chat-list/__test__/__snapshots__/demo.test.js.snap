exports[`ChatList ChatList agent demo works fine 1`] = `
<agent>
  <wx-view
    class="chat-box"
    style="height: calc(100vh - 96rpx - 60px);"
  >
    <t-chat>
      <t-chat-message
        avatar="https://tdesign.gtimg.com/site/chat-avatar.png"
        chatId="key-1"
        datetime=""
        name=""
        placement="left"
        role="assistant"
        bind:message-longpress="showPopover"
      >
        <wx-view
          slot="content"
        >
          <t-chat-content
            content="{{
              Object {
                "data": "欢迎使用TDesign Agent家庭活动策划助手，请给我布置任务吧～",
                "type": "text",
              }
            }}"
          />
        </wx-view>
      </t-chat-message>
      <wx-view
        slot="footer"
      >
        <t-chat-sender
          autoRiseWithKeyboard="{{true}}"
          disabled="{{false}}"
          loading="{{false}}"
          renderPresets="{{
            Array [
              Object {
                "name": "send",
                "type": "icon",
              },
            ]
          }}"
          value=""
          bind:focus="onFocus"
          bind:send="onSend"
          bind:stop="onStop"
        />
      </wx-view>
    </t-chat>
    <t-chat-actionbar
      class="popover-actionbar"
      longPressPosition="{{null}}"
      placement="longpress"
      bind:actions="handlePopoverAction"
    />
  </wx-view>
  <t-toast
    id="t-toast"
  />
</agent>
`;

exports[`ChatList ChatList base demo works fine 1`] = `
<base>
  <wx-view
    class="chat-box"
    style="height: calc(100vh - 96rpx - 60px);"
  >
    <t-chat
      id="chatList"
      bind:scroll="onScroll"
    >
      <t-chat-message
        avatar="https://tdesign.gtimg.com/site/chat-avatar.png"
        chatId="key-1"
        content="{{
          Array [
            Object {
              "data": "它叫 McMurdo Station ATM，是美国富国银行安装在南极洲最大科学中心麦克默多站的一台自动提款机。",
              "type": "text",
            },
          ]
        }}"
        datetime=""
        name=""
        placement="left"
        role="assistant"
        status="complete"
        bind:message-longpress="showPopover"
      >
        <t-chat-actionbar
          chatId="key-1"
          comment=""
          id="actionbar-key-1"
          placement="end"
          slot="actionbar"
          bind:actions="handleAction"
        />
      </t-chat-message>
      <t-chat-message
        avatar=""
        chatId="key-2"
        content="{{
          Array [
            Object {
              "data": "牛顿第一定律是否适用于所有参考系？",
              "type": "text",
            },
          ]
        }}"
        datetime=""
        name=""
        placement="right"
        role="user"
        status=""
        bind:message-longpress="showPopover"
      />
      <wx-view
        slot="footer"
      >
        <t-chat-sender
          autoRiseWithKeyboard="{{true}}"
          disabled="{{false}}"
          loading="{{false}}"
          renderPresets="{{
            Array [
              Object {
                "name": "send",
                "type": "icon",
              },
            ]
          }}"
          value=""
          bind:focus="onFocus"
          bind:send="onSend"
          bind:stop="onStop"
        />
      </wx-view>
    </t-chat>
    <t-chat-actionbar
      class="popover-actionbar"
      longPressPosition="{{null}}"
      placement="longpress"
      bind:actions="handlePopoverAction"
    />
  </wx-view>
  <t-toast
    id="t-toast"
  />
</base>
`;

