exports[`ChatList ChatList docs demo works fine 1`] = `
<docs>
  <wx-view
    class="chat-box"
    style="height: calc(100vh - 96rpx - 60px);"
  >
    <t-chat>
      <t-chat-message
        avatar="https://tdesign.gtimg.com/site/chat-avatar.png"
        chatContentProps="{{
          Object {
            "thinking": Object {
              "collapsed": true,
              "maxHeight": 100,
            },
          }
        }}"
        chatId="key-1"
        content="{{
          Array [
            Object {
              "data": "欢迎使用TDesign文案写作助手，可以先上传你需要参考的文件，输入你要撰写的主题~",
              "type": "text",
            },
          ]
        }}"
        datetime=""
        name=""
        placement="left"
        role="assistant"
        bind:message-longpress="showPopover"
      />
      <wx-view
        slot="footer"
      >
        <t-chat-sender
          attachmentsProps="{{
            Object {
              "imageViewer": true,
              "items": Array [],
              "removable": true,
            }
          }}"
          autoRiseWithKeyboard="{{true}}"
          disabled="{{false}}"
          fileList="{{Array []}}"
          loading="{{false}}"
          renderPresets="{{
            Array [
              Object {
                "name": "upload",
                "presets": Array [
                  "uploadCamera",
                  "uploadImage",
                  "uploadAttachment",
                ],
                "status": "",
              },
              Object {
                "name": "send",
                "type": "icon",
              },
            ]
          }}"
          value=""
          visible="{{false}}"
          bind:fileChange="onFileChange"
          bind:fileDelete="onFileDelete"
          bind:focus="onFocus"
          bind:keyboardheightchange="onkeyboardheightchange"
          bind:send="onSend"
          bind:stop="onStop"
          bind:updateVisible="onUpdateVisible"
        />
      </wx-view>
    </t-chat>
    <t-chat-actionbar
      class="popover-actionbar"
      longPressPosition="{{null}}"
      placement="longpress"
      bind:actions="handlePopoverAction"
    />
  </wx-view>
  <t-toast
    id="t-toast"
  />
</docs>
`;

