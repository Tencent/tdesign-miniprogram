          loading="{{false}}"
          placeholder="请输入消息..."
          renderPresets="{{
            Array [
              Object {
                "name": "send",
                "type": "icon",
              },
            ]
          }}"
          textareaProps="{{
            Object {
              "autosize": Object {
                "maxHeight": 264,
                "minHeight": 48,
              },
            }
          }}"
          value=""
          visible="{{false}}"
          bind:blur="onBlur"
          bind:change="onChange"
          bind:fileChange="onFileChange"
          bind:fileClick="onFileClick"
          bind:fileDelete="onFileDelete"
          bind:fileSelect="onFileSelect"
          bind:focus="onFocus"
          bind:keyboardheightchange="onKeyboardHeightChange"
          bind:send="onSend"
          bind:stop="onStop"
          bind:updateVisible="onUpdateVisible"
          bind:uploadClick="onUploadClick"
        >
          <wx-view
            class="demo-header"
            slot="header"
          >
            <wx-view
              style="padding: 4rpx; height: 40rpx; color: var(--td-text-color-disabled)"
            >
              <t-icon
                name="enter"
                size="40rpx"
                style="transform: scaleX(-1)"
              />
            </wx-view>
            <wx-view
              class="header-content"
            >
               牛顿第一定律并不适用于所有参考系，它只适用于惯性参考系。在质点不受外力作用时，能够判断出质点静止或作匀速直线运动的参考系一定是惯性参考系，因此只有在惯性参考系中牛顿第一定律才适用。 
            </wx-view>
            <wx-view
              style="padding: 4rpx; height: 40rpx; margin-left: auto; color: var(--td-text-color-placeholder)"
            >
              <t-icon
                name="close"
                size="40rpx"
                bind:tap="handleCLoseCite"
              />
            </wx-view>
          </wx-view>
          <wx-view
            class="demo-footer-prefix"
            slot="footer-prefix"
          >
            <wx-view
              class="deep-think-block "
              bind:tap="onDeepThinkTap"
            >
              <t-icon
                name="system-sum"
                size="36rpx"
              />
              <wx-text
                class="deep-think-text"
              >
                深度思考
              </wx-text>
            </wx-view>
            <wx-view
              class="net-search-block "
              bind:tap="onNetSearchTap"
            >
              <t-icon
                name="internet"
                size="36rpx"
              />
            </wx-view>
          </wx-view>
        </t-chat-sender>
      </wx-view>
      <wx-view
        class="demo-content-citation-footer"
      >
         内容由AI生成，仅供参考 
      </wx-view>
    </wx-view>
  </wx-view>
</content-citation>
`;

