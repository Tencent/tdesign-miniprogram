exports[`ChatSender ChatSender attachments demo works fine 1`] = `
<attachments>
  <wx-view
    class="demo-attachments-container show-upload-menu"
  >
    <wx-view
      class="chat-sender-demo-wrapper"
    >
      <wx-view
        class="chat-sender-height-limit"
      >
        <wx-view
          class="chat-sender-height-left-limit"
        />
        <wx-view
          class="chat-sender-height-right-limit"
        />
      </wx-view>
      <wx-view
        class="chat-sender-placeholder"
      >
         高度限制：最大高度为132px 
      </wx-view>
      <wx-view
        class="chat-sender-wrapper"
        style="bottom:32rpx;"
      >
        <t-chat-sender
          attachmentsProps="{{
            Object {
              "imageViewer": true,
              "items": Array [
                Object {
                  "fileType": "image",
                  "name": "图片1.png",
                  "url": "https://tdesign.gtimg.com/site/square.png",
                },
                Object {
                  "fileType": "pdf",
                  "name": "文档.pdf",
                  "size": 3072,
                  "status": "pending",
                  "url": "https://example.com/document.pdf",
                },
              ],
              "removable": true,
            }
          }}"
          disabled="{{false}}"
          fileList="{{
            Array [
              Object {
                "fileType": "image",
                "name": "图片1.png",
                "url": "https://tdesign.gtimg.com/site/square.png",
              },
              Object {
                "fileType": "pdf",
                "name": "文档.pdf",
                "size": 3072,
                "status": "pending",
                "url": "https://example.com/document.pdf",
              },
            ]
          }}"
          loading="{{false}}"
          placeholder="请输入消息..."
          renderPresets="{{
            Array [
              Object {
                "name": "upload",
                "presets": Array [
                  "uploadCamera",
                  "uploadImage",
                  "uploadAttachment",
                ],
                "status": "",
                "type": "bottom",
              },
              Object {
                "name": "send",
                "type": "icon",
              },
            ]
          }}"
          textareaProps="{{
            Object {
              "autosize": Object {
                "maxHeight": 264,
                "minHeight": 48,
              },
            }
          }}"
          value=""
          visible="{{true}}"
          bind:blur="onBlur"
          bind:change="onChange"
          bind:fileChange="onFileChange"
          bind:fileClick="onFileClick"
          bind:fileDelete="onFileDelete"
          bind:fileSelect="onFileSelect"
          bind:focus="onFocus"
          bind:keyboardheightchange="onKeyboardHeightChange"
          bind:send="onSend"
          bind:stop="onStop"
          bind:updateVisible="onUpdateVisible"
          bind:uploadClick="onUploadClick"
        >
          <wx-view
            class="demo-footer-prefix"
            slot="footer-prefix"
          >
            <wx-view
              class="deep-think-block "
              bind:tap="onDeepThinkTap"
            >
              <t-icon
                name="system-sum"
                size="36rpx"
              />
              <wx-text
                class="deep-think-text"
              >
                深度思考
              </wx-text>
            </wx-view>
            <wx-view
              class="net-search-block "
              bind:tap="onNetSearchTap"
            >
              <t-icon
                name="internet"
                size="36rpx"
              />
            </wx-view>
          </wx-view>
        </t-chat-sender>
      </wx-view>
    </wx-view>
  </wx-view>
  <t-toast
    id="t-toast"
  />
</attachments>
`;

