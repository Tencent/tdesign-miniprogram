# Knot AG-UI 凭据（必填，从 https://knot.woa.com 获取）
KNOT_AGENT_ID=
KNOT_API_TOKEN=
# 团队 token 时必填
KNOT_API_USER=
# Knot 模型名（实际由 Knot Agent 侧固定）
KNOT_MODEL=kimi-k2.6

# 本地 OpenAI 兼容代理监听端口
KNOT_PROXY_PORT=3939

# COS 凭据（视觉模型上传截图用）
# 推荐：使用 e2e-knot-proxy 默认的公有读桶 image-1251917893，只需填 SecretId/Key
# 申请地址：https://console.cloud.tencent.com/cam/capi
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=image-1251917893
COS_REGION=ap-guangzhou
COS_KEY_PREFIX=tdesign-uniapp-x-harness/

# 本地 H5 baseline 地址（HBuilderX gui 自动跑的 H5 服务）
LOCAL_H5_BASE=http://localhost:5177/web

# uniapp 官方 baseline
REMOTE_BASELINE_BASE=https://tdesign.tencent.com/uniapp/live
