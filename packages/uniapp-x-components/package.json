{
  "name": "@tdesign/uniapp-x",
  "version": "0.0.0",
  "private": true,
  "description": "TDesign Uniapp X 组件库（uts 兼容 + 原子化变体 + Shadcn 风格 registry）",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "registry.json",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:registry": "node ./cli/build-registry.mjs",
    "sync": "node ./cli/sync-to-hbuilderx.mjs",
    "sync:watch": "node ./cli/sync-to-hbuilderx.mjs --watch",
    "sync:dry": "node ./cli/sync-to-hbuilderx.mjs --dry-run",
    "audit": "node ./cli/sync/report.mjs --all",
    "audit:props": "node ./cli/sync/audit-props.mjs",
    "audit:tokens": "node ./cli/sync/audit-tokens.mjs",
    "audit:typecheck": "node ./cli/sync/typecheck.mjs",
    "sync:props": "node ./cli/sync/sync-props.mjs",
    "sync:tokens": "node ./cli/sync/sync-tokens.mjs"
  },
  "keywords": [
    "tdesign",
    "uniapp",
    "uniapp-x",
    "uts",
    "uvue",
    "components",
    "shadcn",
    "atomic-css"
  ],
  "author": "TDesign UI",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}