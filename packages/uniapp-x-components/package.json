{
  "name": "@tdesign/uniapp-x",
  "version": "0.0.0",
  "private": true,
  "description": "TDesign UniApp X 组件库（uts 兼容 + 原子化变体 + Shadcn 风格 registry）",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "registry.json",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build:registry": "node ./cli/build-registry.mjs",
    "sync": "node ./cli/sync-to-hbuilderx.mjs",
    "sync:watch": "node ./cli/sync-to-hbuilderx.mjs --watch",
    "sync:dry": "node ./cli/sync-to-hbuilderx.mjs --dry-run"
  },
  "keywords": [
    "tdesign",
    "uniapp",
    "uniapp-x",
    "uts",
    "uvue",
    "components",
    "shadcn",
    "atomic-css"
  ],
  "author": "TDesign UI",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vue/test-utils": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:"
  }
}