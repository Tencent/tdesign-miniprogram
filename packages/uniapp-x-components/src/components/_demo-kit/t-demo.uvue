  flex-direction: column;

  &--notitle {
    margin-top: 0;
  }

  &__header {
    margin: 0 16px;
    display: flex;
    flex-direction: column;

    &-title {
      font-weight: 700;
      font-size: 18px;
      line-height: 26px;
      color: rgba(0, 0, 0, 0.9);
    }

    &-desc {
      margin-top: 8px;
      font-size: 14px;
      line-height: 22px;
