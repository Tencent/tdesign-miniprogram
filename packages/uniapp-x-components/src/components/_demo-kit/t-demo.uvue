<template>
  <view class="t-demo-block" :class="{ 't-demo-block--notitle': title.length === 0 }">
    <view v-if="title.length > 0 || desc.length > 0" class="t-demo-block__header">
      <text v-if="title.length > 0" class="t-demo-block__header-title">{{ title }}</text>
      <text v-if="desc.length > 0" class="t-demo-block__header-desc">{{ desc }}</text>
    </view>
    <view class="t-demo-block__slot">
      <slot />
    </view>
  </view>
</template>

<script setup lang="uts">
/**
 * 内部 demo 容器（与 @tdesign/uniapp 的 t-demo 视觉对齐）：
 * 不带白底卡片，只负责"分组间距 + title/desc"。slot 内组件自己贴底色形成列表效果。
 *
 * 仅用于 _example/ 调试页，不随插件发布。
 */
defineProps({
  title: { type: String, default: '' },
  desc: { type: String, default: '' },
});
</script>

<style lang="less">
.t-demo-block {
  margin: 32px 0 0;
