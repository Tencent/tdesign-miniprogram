<template>
  <view>
    <view v-if="fontReady" class="demo-icon-list">
      <view
        v-for="(item, index) in prefixIcons"
        :key="index"
        class="demo-icon-card"
      >
        <t-icon
          :glyph-char="item.char"
          custom-style="font-family: 'my-icon'"
          size="48rpx"
        />
        <text class="demo-icon-name">{{ item.name }}</text>
      </view>
    </view>
    <view v-else class="demo-loading">
      <text class="demo-loading-text">字体加载中…</text>
    </view>
  </view>
</template>

<script setup lang="uts">
import { ref, onMounted } from 'vue';

type PrefixItem = {
  name: string;
  char: string;
};

const prefixIcons : PrefixItem[] = [
  { name: 'a-0', char: '\ue64d' },
  { name: 'a-1h', char: '\ue64e' },
  { name: 'a-2h', char: '\ue64f' },
  { name: 'a-3h', char: '\ue650' },
];

// 自定义字体（base64 woff2，与 uniapp 版 custom/index.vue 同源）
const MY_ICON_FONT_SRC = "url('data:application/x-font-woff2;charset=utf-8;base64,') format('woff2')";

const fontReady = ref(false);

onMounted(() => {
  // 关键：uvue 中 <style> 的 @font-face 受组件作用域隔离影响，子组件 <text> 看不到。
  // 改用 uni.loadFontFace 全局注册字体，跨组件可用。
  uni.loadFontFace({
    family: 'my-icon',
    source: MY_ICON_FONT_SRC,
    global: true,
    success: () => {
      fontReady.value = true;
    },
    fail: () => {
      // 即使失败也展示，避免一直白屏
      fontReady.value = true;
    },
  });
});
</script>

<style>
.demo-icon-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 16rpx 32rpx;
}
.demo-icon-card {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.demo-icon-name {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  color: #999999;
  text-align: center;
}
.demo-loading {
  padding: 32rpx;
}
.demo-loading-text {
  font-size: 24rpx;
  color: #999999;
}
</style>
